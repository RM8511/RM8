-- RM8 FOCUS SYSTEM: Westbound Silent Aim (Target Nearest to Cursor)
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local Camera = game.Workspace.CurrentCamera

-- إعدادات RM8 المركزة
local RM8_Config = {
    Enabled = true,
    TargetPart = "HumanoidRootPart", -- الصدر (أكثر أماناً)
    MaxDistance = 350, -- المسافة القصوى
    FieldOfView = 80 -- زاوية الرؤية (فقط اللي قدامك بمدى بصري طبيعي)
}

-- دالة لاختيار الشخص "المقصود" (الأقرب للماوس)
local function GetBestTarget()
    local BestTarget = nil
    local SmallestMagnitude = RM8_Config.FieldOfView * 10 -- البحث في محيط الماوس

    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(RM8_Config.TargetPart) then
            local Humanoid = v.Character:FindFirstChild("Humanoid")
            if Humanoid and Humanoid.Health > 0 then
                
                -- تحويل موقع الخصم لنقطة على الشاشة
                local ScreenPoint, OnScreen = Camera:WorldToViewportPoint(v.Character[RM8_Config.TargetPart].Position)
                
                if OnScreen then
                    -- حساب المسافة بين الخصم وبينك
                    local Distance = (LocalPlayer.Character.HumanoidRootPart.Position - v.Character[RM8_Config.TargetPart].Position).Magnitude
                    
                    -- حساب المسافة بين مؤشر الماوس وموقع الخصم على الشاشة
                    local Magnitude = (Vector2.new(ScreenPoint.X, ScreenPoint.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    
                    if Distance < RM8_Config.MaxDistance and Magnitude < SmallestMagnitude then
                        -- فحص الجدران (التأكد أنه قدامك مو وراء عائق)
                        local RayParams = RaycastParams.new()
                        RayParams.FilterDescendantsInstances = {LocalPlayer.Character, v.Character}
                        RayParams.FilterType = Enum.RaycastFilterType.Exclude
                        
                        local RayResult = game.Workspace:Raycast(Camera.CFrame.Position, (v.Character[RM8_Config.TargetPart].Position - Camera.CFrame.Position).Unit * Distance, RayParams)
                        
                        if not RayResult then -- إذا الطريق فاضي
                            BestTarget = v
                            SmallestMagnitude = Magnitude
                        end
                    end
                end
            end
        end
    end
    return BestTarget
end

-- تفعيل الـ Silent Aim المركز
local OldNamecall
OldNamecall = hookmetamethod(game, "__namecall", function(Self, ...)
    local Args = {...}
    local Method = getnamecallmethod()

    if RM8_Config.Enabled and Method == "FindPartOnRayWithIgnoreList" then
        local Target = GetBestTarget()
        if Target and Target.Character then
            -- توجيه الرصاصة للشخص اللي "أنت" مصوب قريب منه
            Args[1] = Ray.new(Camera.CFrame.Position, (Target.Character[RM8_Config.TargetPart].Position - Camera.CFrame.Position).Unit * 1000)
            return OldNamecall(Self, unpack(Args))
        end
    end
    return OldNamecall(Self, ...)
end)

print("RM8 Focus System: Active. Targets the closest person to your cursor.")
