-- [[ RM8 WESTBOUND v1.5 - SPECIAL RED EDITION ]] --
local Library = loadstring(game:HttpGet("https://raw.githubusercontent.com/xHeptc/Kavo-UI-Library/main/source.lua"))()

local RM8_Colors = {
    SchemeColor = Color3.fromRGB(255, 0, 0), 
    Background = Color3.fromRGB(0, 0, 0), 
    Header = Color3.fromRGB(10, 10, 10),
    TextColor = Color3.fromRGB(255, 255, 255),
    ElementColor = Color3.fromRGB(15, 15, 15)
}

local Window = Library.CreateLib("RM8 WESTBOUND v1.5", RM8_Colors)

-- [ الزر العائم RM8 ] --
local ScreenGui = Instance.new("ScreenGui", game:GetService("CoreGui"))
local ToggleButton = Instance.new("TextButton", ScreenGui)
local Corner = Instance.new("UICorner", ToggleButton)
local Stroke = Instance.new("UIStroke", ToggleButton)

ToggleButton.Size = UDim2.new(0, 70, 0, 40)
ToggleButton.Position = UDim2.new(0.05, 0, 0.45, 0) -- غيرنا مكانه شوي عشان ما يغطي على سكربت المملكة
ToggleButton.BackgroundColor3 = Color3.fromRGB(0, 0, 0)
ToggleButton.Text = "RM8"
ToggleButton.TextColor3 = Color3.fromRGB(255, 0, 0)
ToggleButton.Font = Enum.Font.GothamBold
ToggleButton.Draggable = true
ToggleButton.Active = true
Corner.CornerRadius = UDim.new(0, 10)
Stroke.Color = Color3.fromRGB(255, 0, 0)
Stroke.Thickness = 2.5

ToggleButton.MouseButton1Click:Connect(function() Library:ToggleUI() end)

-- [ الإعدادات ] --
local RM8_Config = { SilentAim = false, SilentFOV = 250, InfStamina = false }

-- [ قسم القتال ] --
local CombatTab = Window:NewTab("القتال (Combat)")
local CombatSec = CombatTab:NewSection("أدوات الصيد")

CombatSec:NewToggle("تفعيل Silent Aim", "الرصاص يلحق الهدف", function(state) RM8_Config.SilentAim = state end)
CombatSec:NewSlider("نطاق الـ FOV", "مساحة الهدف", 800, 50, function(v) RM8_Config.SilentFOV = v end)

-- [ قسم اللاعب ] --
local PlayerTab = Window:NewTab("اللاعب (Player)")
local PlayerSec = PlayerTab:NewSection("قدرات خاصة")

PlayerSec:NewToggle("لا نهائي Stamina", "تركض بدون تعب", function(state)
    RM8_Config.InfStamina = state
end)

-- [[ محرك التشغيل الخلفي ]] --
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()

-- ميزة الـ Stamina لـ Westbound
game:GetService("RunService").RenderStepped:Connect(function()
    if RM8_Config.InfStamina then
        if LocalPlayer.Character and LocalPlayer.Character:FindFirstChild("Stamina") then
            LocalPlayer.Character.Stamina.Value = 100
        end
    end
end)

-- محرك الـ Silent Aim (نظام Mouse Hit)
local OldIndex
OldIndex = hookmetamethod(game, "__index", function(self, index)
    if self == Mouse and (index == "Hit" or index == "Target") and RM8_Config.SilentAim then
        local Target = nil
        local Dist = RM8_Config.SilentFOV
        for _, v in pairs(Players:GetPlayers()) do
            if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild("Head") then
                local Pos, OnScreen = game.Workspace.CurrentCamera:WorldToViewportPoint(v.Character.Head.Position)
                if OnScreen then
                    local Mag = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if Mag < Dist then
                        Target = v
                        Dist = Mag
                    end
                end
            end
        end
        if Target then
            return (index == "Hit" and Target.Character.Head.CFrame or Target.Character.Head)
        end
    end
    return OldIndex(self, index)
end)
