-- [[ محرك RM8 التقني ]] --
local Players = game:GetService("Players")
local LocalPlayer = Players.LocalPlayer
local Mouse = LocalPlayer:GetMouse()
local Camera = game.Workspace.CurrentCamera

local function GetTarget(MaxDist)
    local Closest = nil
    local DistLimit = MaxDist
    for _, v in pairs(Players:GetPlayers()) do
        if v ~= LocalPlayer and v.Character and v.Character:FindFirstChild(RM8_Config.TargetPart) then
            local Hum = v.Character:FindFirstChild("Humanoid")
            if Hum and Hum.Health > 0 then
                local Pos, OnScreen = Camera:WorldToViewportPoint(v.Character[RM8_Config.TargetPart].Position)
                if OnScreen then
                    local Mag = (Vector2.new(Pos.X, Pos.Y) - Vector2.new(Mouse.X, Mouse.Y)).Magnitude
                    if Mag < DistLimit then
                        Closest = v
                        DistLimit = Mag
                    end
                end
            end
        end
    end
    return Closest
end

-- نظام Silent Aim
local OldIndex
OldIndex = hookmetamethod(game, "__index", function(self, index)
    if self == Mouse and (index == "Hit" or index == "Target") and RM8_Config.SilentAim then
        local Target = GetTarget(RM8_Config.SilentFOV)
        if Target and Target.Character and Target.Character:FindFirstChild(RM8_Config.TargetPart) then
            return (index == "Hit" and Target.Character[RM8_Config.TargetPart].CFrame or Target.Character[RM8_Config.TargetPart])
        end
    end
    return OldIndex(self, index)
end)

-- نظام Aimbot
game:GetService("RunService").RenderStepped:Connect(function()
    if RM8_Config.Aimbot and game:GetService("UserInputService"):IsMouseButtonPressed(Enum.UserInputType.MouseButton2) then
        local T = GetTarget(RM8_Config.AimbotFOV)
        if T then
            Camera.CFrame = Camera.CFrame:Lerp(CFrame.new(Camera.CFrame.Position, T.Character[RM8_Config.TargetPart].Position), 0.1)
        end
    end
end)
